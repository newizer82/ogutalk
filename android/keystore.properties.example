# 이 파일을 복사해서 `keystore.properties` 로 저장한 뒤 실제 값을 채우세요.
# `keystore.properties` 는 .gitignore 로 보호되어 절대 git 에 커밋되지 않습니다.
#
# storeFile: 키스토어 파일 경로 (이 properties 파일 기준 상대경로 OK)
#            android/app/ogutalk-release.keystore 에 두면 → "app/ogutalk-release.keystore"

storeFile=app/ogutalk-release.keystore
storePassword=여기에_키스토어_비밀번호
keyAlias=ogutalk
keyPassword=여기에_키_비밀번호
